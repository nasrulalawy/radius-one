<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'vouchers', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: title }) %>
    <div class="app-content">
    <h1><%= title %></h1>
    <div class="card">
      <form method="post" action="/vouchers/generate">
        <div class="form-group">
          <label>Router</label>
          <select name="router_id" required>
            <% routers.forEach(function(r) { %>
            <option value="<%= r.id %>"><%= r.name %> (<%= r.host %>)</option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label>Paket (opsional)</label>
          <select name="package_id">
            <option value="">-- Pilih --</option>
            <% packages.forEach(function(p) { %>
            <option value="<%= p.id %>"><%= p.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label>Prefix kode</label>
          <input type="text" name="prefix" value="V" placeholder="V">
        </div>
        <div class="form-group">
          <label>Jumlah voucher (maks 100)</label>
          <input type="number" name="count" value="10" min="1" max="100">
        </div>
        <div class="form-group">
          <label>Durasi (menit)</label>
          <input type="number" name="duration_minutes" value="60" min="1">
        </div>
        <button type="submit" class="btn btn-primary">Generate</button>
        <a href="/vouchers" class="btn btn-secondary" style="margin-left: 0.5rem;">Batal</a>
      </form>
    </div>
    </div>
  </div>
</body>
</html>
