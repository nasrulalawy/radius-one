<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body>
  <nav class="nav">
    <span class="brand">Portal Pelanggan</span>
    <a href="/client">Beranda</a>
    <a href="/client/bills">Tagihan</a>
    <a href="/client/logout">Logout</a>
  </nav>
  <main>
    <h1>Tagihan Saya</h1>
    <div class="card">
      <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Periode</th><th>Jumlah</th><th>Jatuh tempo</th><th>Status</th><th>Aksi</th></tr>
        </thead>
        <tbody>
          <% if (bills.length) { bills.forEach(function(b) { %>
          <tr>
            <td><%= b.period_start %> — <%= b.period_end %></td>
            <td>Rp <%= Number(b.amount).toLocaleString('id-ID') %></td>
            <td><%= b.due_date || '-' %></td>
            <td><span class="badge <%= b.status === 'paid' ? 'badge-paid' : 'badge-unpaid' %>"><%= b.status %></span></td>
            <td>
              <% if (b.status === 'unpaid') { %>
              <form method="post" action="/client/bills/<%= b.id %>/pay" style="display:inline;">
                <input type="hidden" name="method" value="konfirmasi">
                <button type="submit" class="btn btn-primary">Konfirmasi sudah bayar</button>
              </form>
              <% } else { %>
              Lunas
              <% } %>
            </td>
          </tr>
          <% }); } else { %>
          <tr><td colspan="5" style="color: var(--muted);">Belum ada tagihan.</td></tr>
          <% } %>
        </tbody>
      </table>
      </div>
    </div>
    <p class="muted text-sm">Setelah transfer, klik "Konfirmasi sudah bayar". Admin akan verifikasi jika diperlukan.</p>
  </main>
</body>
</html>
