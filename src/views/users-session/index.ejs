<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'users-session', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: 'Users Session' }) %>
    <div class="app-content">
      <h1>Users Session</h1>
      <div class="stats-grid">
        <div class="stat"><div class="num"><%= stats.hotspotUsers %></div><div class="label">Hotspot Users</div></div>
        <div class="stat"><div class="num"><%= stats.pppUsers %></div><div class="label">PPPoE Users</div></div>
        <div class="stat"><div class="num"><%= stats.activeHotspot %></div><div class="label">Hotspot Active</div></div>
        <div class="stat"><div class="num"><%= stats.activePpp %></div><div class="label">PPPoE Active</div></div>
        <div class="stat"><div class="num"><%= stats.liveHotspot %></div><div class="label">Hotspot Live Session</div></div>
        <div class="stat"><div class="num"><%= stats.livePpp %></div><div class="label">PPPoE Live Session</div></div>
        <div class="stat"><div class="num"><%= stats.totalVouchers %></div><div class="label">Total Voucher</div></div>
        <div class="stat"><div class="num"><%= stats.usedVouchers %></div><div class="label">Voucher Terpakai</div></div>
      </div>
      <div class="card">
        <h2>Live Session per Router</h2>
        <% if (!perRouterLive || perRouterLive.length === 0) { %>
          <p class="muted">Belum ada router terdaftar.</p>
        <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Router</th>
                  <th>Mode</th>
                  <th>PPPoE Active</th>
                  <th>Hotspot Active</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% perRouterLive.forEach(function(row) { %>
                  <tr>
                    <td><%= row.router.name %></td>
                    <td><%= row.mode || row.router.integration_mode || 'api' %></td>
                    <td><%= row.pppActive %></td>
                    <td><%= row.hotspotActive %></td>
                    <td>
                      <% if (row.ok) { %>
                        <span class="badge badge-active">OK</span>
                      <% } else { %>
                        <span class="badge badge-unpaid"><%= row.error || 'Error' %></span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
