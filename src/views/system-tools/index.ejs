<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'system-tools', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: 'System Tools' }) %>
    <div class="app-content">
      <h1>System Tools</h1>
      <% if (restored) { %>
        <div class="alert alert-success">Restore berhasil. Data aplikasi sudah diperbarui.</div>
      <% } %>
      <% if (typeof imported !== 'undefined' && imported !== null && imported !== '') { %>
        <div class="alert alert-success">Import user selesai: berhasil <strong><%= imported %></strong>, gagal <strong><%= failed || 0 %></strong>.</div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <div class="card">
        <h2>Backup Data</h2>
        <p class="muted">Download semua data aplikasi (database + app settings) dalam format JSON.</p>
        <a href="/system-tools/backup" class="btn btn-primary">Download Backup JSON</a>
      </div>

      <div class="card">
        <h2>Import User (CSV)</h2>
        <p class="muted">Format header: <code>name,username,password,type,router_id,package_id,address,phone,status</code></p>
        <form method="post" action="/system-tools/import-users">
          <div class="form-group">
            <label>CSV Data</label>
            <textarea name="import_csv" rows="10" style="max-width:none;width:100%;" placeholder="name,username,password,type,router_id,package_id,address,phone,status"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Import Sekarang</button>
        </form>
      </div>

      <div class="card">
        <h2>Restore Data</h2>
        <p class="muted">Paste isi file backup JSON di bawah ini untuk restore penuh.</p>
        <form method="post" action="/system-tools/restore">
          <div class="form-group">
            <label>Backup JSON</label>
            <textarea name="backup_json" rows="14" style="max-width:none;width:100%;" placeholder='{"database": {...}, "app_settings": {...}}'></textarea>
          </div>
          <button type="submit" class="btn btn-danger" onclick="return confirm('Restore akan menimpa data saat ini. Lanjutkan?')">Restore Sekarang</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
