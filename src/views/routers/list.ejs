<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'routers', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: 'Router MikroTik' }) %>
    <div class="app-content">
    <div class="page-header">
      <h1><%= title %></h1>
      <a href="/routers/add" class="btn btn-primary">+ Tambah Router</a>
    </div>
    <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (typeof testOk !== 'undefined' && testOk) { %><div class="alert alert-success">Koneksi ke "<%= testOk %>" berhasil.</div><% } %>
    <% if (typeof testError !== 'undefined' && testError) { %><div class="alert alert-error">Koneksi gagal: <%= testError %></div><% } %>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Nama</th><th>Mode</th><th>Host / VPN IP</th><th>Port</th><th>Via VPN</th><th>Aksi</th></tr>
          </thead>
          <tbody>
            <% if (routers.length) { routers.forEach(function(r) { %>
            <tr>
              <td><%= r.name %></td>
              <td><%= (r.integration_mode || 'api').toUpperCase() %></td>
              <td><%= r.use_vpn && r.vpn_ip ? r.vpn_ip : r.host %></td>
              <td><%= r.port %></td>
              <td><%= r.use_vpn ? 'Ya' : '-' %></td>
              <td>
                <a href="/routers/test/<%= r.id %>" class="btn btn-sm btn-secondary" title="Test koneksi">Test</a>
                <a href="/routers/edit/<%= r.id %>" class="btn btn-sm btn-primary">Edit</a>
                <form method="post" action="/routers/delete/<%= r.id %>" style="display:inline;" onsubmit="return confirm('Hapus router ini?');">
                  <button type="submit" class="btn btn-sm btn-danger">Hapus</button>
                </form>
              </td>
            </tr>
            <% }); } else { %>
            <tr><td colspan="6" class="muted">Belum ada router. <a href="/routers/add">Tambah router</a>.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
    </div>
  </div>
</body>
</html>
