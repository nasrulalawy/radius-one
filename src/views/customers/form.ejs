<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'customers', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: title }) %>
    <div class="app-content">
    <h1><%= title %></h1>
    <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <div class="card">
      <form method="post" action="/customers/save">
        <% if (customer && customer.id) { %><input type="hidden" name="id" value="<%= customer.id %>"><% } %>
        <div class="form-group">
          <label>Router</label>
          <select name="router_id" required>
            <% routers.forEach(function(r) { %>
            <option value="<%= r.id %>" <%= (customer && customer.router_id == r.id) ? 'selected' : '' %>><%= r.name %> (<%= r.host %>)</option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label>Paket (opsional)</label>
          <select name="package_id">
            <option value="">-- Pilih --</option>
            <% packages.forEach(function(p) { %>
            <option value="<%= p.id %>" <%= (customer && customer.package_id == p.id) ? 'selected' : '' %>><%= p.name %> - <%= p.type %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label>Nama Pelanggan</label>
          <input type="text" name="name" value="<%= customer ? customer.name : '' %>" required>
        </div>
        <div class="form-group">
          <label>Username (login PPPoE/Hotspot)</label>
          <input type="text" name="username" value="<%= customer ? customer.username : '' %>" required>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" value="<%= customer ? customer.password : '' %>" <%= customer ? '' : 'required' %>>
        </div>
        <div class="form-group">
          <label>Tipe</label>
          <select name="type">
            <option value="pppoe" <%= customer && customer.type === 'pppoe' ? 'selected' : '' %>>PPPoE</option>
            <option value="hotspot" <%= customer && customer.type === 'hotspot' ? 'selected' : '' %>>Hotspot</option>
          </select>
        </div>
        <div class="form-group">
          <label>Status</label>
          <select name="status">
            <option value="active" <%= customer && customer.status === 'active' ? 'selected' : '' %>>Aktif</option>
            <option value="isolir" <%= customer && customer.status === 'isolir' ? 'selected' : '' %>>Isolir</option>
          </select>
        </div>
        <div class="form-group">
          <label>Alamat</label>
          <input type="text" name="address" value="<%= customer ? (customer.address || '') : '' %>">
        </div>
        <div class="form-group">
          <label>Telepon</label>
          <input type="text" name="phone" value="<%= customer ? (customer.phone || '') : '' %>">
        </div>
        <button type="submit" class="btn btn-primary">Simpan</button>
        <a href="/customers" class="btn btn-secondary" style="margin-left: 0.5rem;">Batal</a>
      </form>
    </div>
    </div>
  </div>
</body>
</html>
