<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'customers', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: 'Pelanggan' }) %>
    <div class="app-content">
    <div class="page-header">
      <h1><%= title %></h1>
      <a href="/customers/add" class="btn btn-primary">+ Tambah Pelanggan</a>
    </div>
    <% if (typeof syncError !== 'undefined' && syncError) { %><div class="alert alert-error">Pelanggan tersimpan, gagal ditambah ke router: <%= syncError %></div><% } %>
    <div class="card">
      <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Nama</th><th>Username</th><th>Router</th><th>Paket</th><th>Tipe</th><th>Status</th><th>Aksi</th></tr>
        </thead>
        <tbody>
          <% if (customers.length) { customers.forEach(function(c) { %>
          <tr>
            <td><%= c.name %></td>
            <td><%= c.username %></td>
            <td><%= c.router_name || '-' %></td>
            <td><%= c.package_name || '-' %></td>
            <td><%= c.type %></td>
            <td><span class="badge <%= c.status === 'active' ? 'badge-active' : 'badge-isolir' %>"><%= c.status %></span></td>
            <td>
              <a href="/customers/edit/<%= c.id %>" class="btn btn-primary">Edit</a>
              <% if (c.status === 'active') { %>
              <form method="post" action="/customers/isolir/<%= c.id %>" style="display:inline;">
                <button type="submit" class="btn btn-danger">Isolir</button>
              </form>
              <% } else { %>
              <form method="post" action="/customers/aktifkan/<%= c.id %>" style="display:inline;">
                <button type="submit" class="btn btn-success">Aktifkan</button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }); } else { %>
          <tr><td colspan="7" style="color: var(--muted);">Belum ada pelanggan. <a href="/customers/add">Tambah pelanggan</a>.</td></tr>
          <% } %>
        </tbody>
      </table>
      </div>
    </div>
    </div>
  </div>
</body>
</html>
