<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'reports', subactive: 'statistics', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: 'Statistics' }) %>
    <div class="app-content">
      <h1>Statistics</h1>
      <div class="stats-grid">
        <div class="stat"><div class="num"><%= stats ? stats.customers : 0 %></div><div class="label">Pelanggan</div></div>
        <div class="stat"><div class="num"><%= stats ? stats.packages : 0 %></div><div class="label">Paket</div></div>
        <div class="stat"><div class="num"><%= stats ? stats.routers : 0 %></div><div class="label">Router</div></div>
        <div class="stat"><div class="num"><%= paidCount || 0 %></div><div class="label">Tagihan Lunas</div></div>
        <div class="stat"><div class="num"><%= unpaidCount || 0 %></div><div class="label">Tagihan Belum Lunas</div></div>
        <div class="stat"><div class="num">Rp <%= Number(totalPaid || 0).toLocaleString('id-ID') %></div><div class="label">Total Lunas</div></div>
        <div class="stat"><div class="num">Rp <%= Number(totalUnpaid || 0).toLocaleString('id-ID') %></div><div class="label">Total Belum Lunas</div></div>
      </div>
    </div>
  </div>
</body>
</html>
