<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'software-logs', subactive: 'radius-auth', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: 'Radius Auth Log' }) %>
    <div class="app-content">
      <div class="page-header">
        <h1>Radius Auth Log</h1>
        <form method="get" action="/software-logs/radius-auth">
          <label style="display:inline-block;margin-right:0.4rem;">Limit</label>
          <input type="number" name="limit" min="10" max="1000" value="<%= limit %>" style="width:90px;">
          <button type="submit" class="btn btn-secondary btn-sm">Refresh</button>
        </form>
      </div>
      <div class="card">
        <% if (!logs || logs.length === 0) { %>
          <p class="muted">Belum ada log autentikasi.</p>
        <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Waktu</th>
                  <th>User ID</th>
                  <th>Method</th>
                  <th>Path</th>
                  <th>Status</th>
                  <th>IP</th>
                </tr>
              </thead>
              <tbody>
                <% logs.forEach(function(row) { %>
                <tr>
                  <td><%= (row.at || '').toString().replace('T', ' ').slice(0, 19) %></td>
                  <td><%= row.user_id || '-' %></td>
                  <td><%= row.method || '-' %></td>
                  <td><%= row.path || '-' %></td>
                  <td><%= row.status || '-' %></td>
                  <td><%= row.ip || '-' %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
