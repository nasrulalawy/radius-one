<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'odp-pop', subactive: 'odp-map', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: 'ODP | POP - View Map' }) %>
    <div class="app-content">
      <h1>ODP | POP - View Map</h1>
      <% if (!items || items.length === 0) { %>
        <div class="card">
          <p class="muted">Tidak ada ODP/POP dengan koordinat. <a href="/odp-pop">Kelola ODP/POP</a> dan isi latitude/longitude.</p>
        </div>
      <% } else { %>
        <div class="card" style="padding: 0; overflow: hidden;">
          <div id="map" style="height: 480px; width: 100%;"></div>
        </div>
        <div class="card">
          <p class="muted"><%= items.length %> titik dengan koordinat.</p>
        </div>
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
        <script>
          var items = <%- JSON.stringify(items) %>;
          var center = items.length ? [items[0].latitude, items[0].longitude] : [-6.2, 106.8];
          var map = L.map('map').setView(center, 12);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap' }).addTo(map);
          items.forEach(function(item) {
            L.marker([parseFloat(item.latitude), parseFloat(item.longitude)])
              .bindPopup('<strong>' + (item.name || '') + '</strong><br>' + (item.address || '') + '<br><a href="/odp-pop/edit/' + item.id + '">Edit</a>')
              .addTo(map);
          });
          if (items.length > 1) {
            var bounds = L.latLngBounds(items.map(function(i) { return [parseFloat(i.latitude), parseFloat(i.longitude)]; }));
            map.fitBounds(bounds, { padding: [20, 20] });
          }
        </script>
      <% } %>
    </div>
  </div>
</body>
</html>
