<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'support-tickets', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: 'Support Tickets' }) %>
    <div class="app-content">
      <div class="page-header">
        <h1>Support Tickets</h1>
        <a href="/support-tickets/add" class="btn btn-primary">Buat Ticket</a>
      </div>

      <% if (saved) { %><div class="alert alert-success">Ticket tersimpan.</div><% } %>
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

      <div class="card" style="margin-bottom:1rem;">
        <a href="/support-tickets?status=all" class="btn <%= status === 'all' ? 'btn-primary' : 'btn-secondary' %> btn-sm">All Tickets</a>
        <a href="/support-tickets?status=open" class="btn <%= status === 'open' ? 'btn-primary' : 'btn-secondary' %> btn-sm">Opened Tickets</a>
        <a href="/support-tickets?status=closed" class="btn <%= status === 'closed' ? 'btn-primary' : 'btn-secondary' %> btn-sm">Closed Tickets</a>
      </div>

      <div class="card">
        <% if (!tickets || tickets.length === 0) { %>
          <p class="muted">Belum ada ticket.</p>
        <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Subjek</th>
                  <th>Pelanggan</th>
                  <th>Prioritas</th>
                  <th>Status</th>
                  <th>Dibuat</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% tickets.forEach(function(t) { %>
                <tr>
                  <td>#<%= t.id %></td>
                  <td><strong><%= t.subject %></strong><br><span class="muted"><%= (t.description || '').slice(0, 80) %></span></td>
                  <td><%= t.customer_name || '-' %></td>
                  <td><%= (t.priority || 'normal').toUpperCase() %></td>
                  <td><span class="badge <%= t.status === 'closed' ? 'badge-paid' : 'badge-unpaid' %>"><%= t.status %></span></td>
                  <td><%= (t.created_at || '').toString().replace('T', ' ').slice(0, 19) %></td>
                  <td>
                    <a href="/support-tickets/edit/<%= t.id %>" class="btn btn-secondary btn-sm">Edit</a>
                    <% if (t.status !== 'closed') { %>
                    <form method="post" action="/support-tickets/close/<%= t.id %>" style="display:inline;" onsubmit="return confirm('Tutup ticket ini?')">
                      <button type="submit" class="btn btn-danger btn-sm">Close</button>
                    </form>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
