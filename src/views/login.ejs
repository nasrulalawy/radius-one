<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="login-page">
  <div class="login-box">
    <h1>Radius One</h1>
    <p class="subtitle">Login admin Supabase Auth (email atau username admin)</p>
    <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <form method="post" action="/login">
      <input type="text" name="username" placeholder="Username / Email" required autofocus>
      <input type="password" name="password" placeholder="Password" required>
      <button type="submit" class="btn btn-primary">Login</button>
    </form>
  </div>
</body>
</html>
