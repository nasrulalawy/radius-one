<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'neighbor-list', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: 'Neighbor List' }) %>
    <div class="app-content">
      <h1>Neighbor List</h1>
      <div class="card">
        <p class="muted">Daftar tetangga (neighbor) dari router. Integrasi dengan MikroTik wireless neighbor list dapat ditambahkan.</p>
        <% if (routers && routers.length > 0) { %>
          <p>Router terdaftar: <%= routers.length %>. Pilih router untuk mengambil neighbor list.</p>
        <% } else { %>
          <p>Belum ada router. <a href="/routers">Daftar router</a> terlebih dahulu.</p>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
