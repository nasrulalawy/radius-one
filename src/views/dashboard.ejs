<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body class="app-with-sidebar">
  <%- include('partials/sidebar', { active: 'dashboard', user }) %>
  <div class="app-main">
    <%- include('partials/topbar', { title: 'Dashboard' }) %>
    <div class="app-content">
      <h1>Dashboard</h1>

      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Ringkasan</h2>
        <div class="stats-grid stats-grid-dashboard">
          <div class="stat stat-card">
            <div class="stat-icon">📡</div>
            <div class="stat-body">
              <div class="num"><%= stats.routers %></div>
              <div class="label">Router Aktif</div>
            </div>
          </div>
          <div class="stat stat-card">
            <div class="stat-icon">👥</div>
            <div class="stat-body">
              <div class="num"><%= stats.customers %></div>
              <div class="label">Total Pelanggan</div>
            </div>
          </div>
          <div class="stat stat-card">
            <div class="stat-icon">🟢</div>
            <div class="stat-body">
              <div class="num"><%= stats.active %></div>
              <div class="label">Pelanggan Aktif</div>
            </div>
          </div>
          <div class="stat stat-card">
            <div class="stat-icon">📦</div>
            <div class="stat-body">
              <div class="num"><%= typeof packagesCount !== 'undefined' ? packagesCount : 0 %></div>
              <div class="label">Paket</div>
            </div>
          </div>
          <div class="stat stat-card stat-warn">
            <div class="stat-icon">📄</div>
            <div class="stat-body">
              <div class="num"><%= stats.unpaid %></div>
              <div class="label">Tagihan Belum Lunas</div>
            </div>
          </div>
          <div class="stat stat-card stat-warn">
            <div class="stat-icon">💰</div>
            <div class="stat-body">
              <div class="num">Rp <%= Number(stats.totalUnpaid || 0).toLocaleString('id-ID') %></div>
              <div class="label">Total Piutang</div>
            </div>
          </div>
          <div class="stat stat-card">
            <div class="stat-icon">🎫</div>
            <div class="stat-body">
              <div class="num"><%= typeof vouchersUsed !== 'undefined' ? vouchersUsed : 0 %> / <%= typeof vouchersTotal !== 'undefined' ? vouchersTotal : 0 %></div>
              <div class="label">Voucher Terpakai / Total</div>
            </div>
          </div>
        </div>
      </section>

      <section class="dashboard-section dashboard-charts">
        <div class="dashboard-chart-card">
          <h3 class="chart-title">Pendapatan 12 Bulan Terakhir</h3>
          <div class="chart-wrap">
            <canvas id="chartRevenue" height="220"></canvas>
          </div>
        </div>
        <div class="dashboard-chart-card">
          <h3 class="chart-title">Pelanggan per Tipe</h3>
          <div class="chart-wrap chart-wrap-doughnut">
            <canvas id="chartCustomerType" height="220"></canvas>
          </div>
        </div>
      </section>

      <section class="dashboard-section dashboard-charts">
        <div class="dashboard-chart-card">
          <h3 class="chart-title">Status Tagihan</h3>
          <div class="chart-wrap chart-wrap-doughnut">
            <canvas id="chartBillsStatus" height="220"></canvas>
          </div>
        </div>
        <div class="dashboard-chart-card dashboard-quick-actions">
          <h3 class="chart-title">Aksi Cepat</h3>
          <div class="quick-actions">
            <a href="/routers" class="quick-action-btn"><span>📡</span> Tambah Router</a>
            <a href="/customers/add" class="quick-action-btn"><span>👤</span> Tambah Pelanggan</a>
            <a href="/bills/add" class="quick-action-btn"><span>📄</span> Buat Tagihan</a>
            <a href="/bills/unpaid" class="quick-action-btn"><span>⚠️</span> Tagihan Belum Lunas</a>
            <a href="/vouchers/generate" class="quick-action-btn"><span>🎫</span> Generate Voucher</a>
            <a href="/client/login" class="quick-action-btn" target="_blank"><span>🌐</span> Portal Pelanggan</a>
          </div>
        </div>
      </section>

      <section class="dashboard-section">
        <h2 class="dashboard-section-title">Pembayaran Terbaru</h2>
        <div class="card">
          <% if (recentPayments && recentPayments.length > 0) { %>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Tanggal</th>
                    <th>Pelanggan</th>
                    <th>Jumlah</th>
                    <th>Metode</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentPayments.forEach(function(p) { %>
                  <tr>
                    <td><%= (p.paid_at || '').toString().slice(0, 16).replace('T', ' ') %></td>
                    <td><%= p.customer_name || '-' %></td>
                    <td>Rp <%= Number(p.amount || 0).toLocaleString('id-ID') %></td>
                    <td><%= p.method || '-' %></td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
            <p style="margin-top: 0.75rem;"><a href="/reports" class="btn btn-secondary btn-sm">Lihat Semua Laporan</a></p>
          <% } else { %>
            <p class="muted">Belum ada pembayaran. <a href="/bills">Kelola tagihan</a>.</p>
          <% } %>
        </div>
      </section>
    </div>
  </div>
  <script>
(function() {
  var revenueData = <%- JSON.stringify(revenueByMonth || []) %>;
  var customerByType = <%- JSON.stringify(customerByType || { hotspot: 0, pppoe: 0 }) %>;
  var billsByStatus = <%- JSON.stringify(billsByStatus || { paid: 0, unpaid: 0 }) %>;

  if (document.getElementById('chartRevenue') && revenueData.length) {
    new Chart(document.getElementById('chartRevenue'), {
      type: 'bar',
      data: {
        labels: revenueData.map(function(d) { return d.label; }),
        datasets: [{
          label: 'Pendapatan (Rp)',
          data: revenueData.map(function(d) { return d.value; }),
          backgroundColor: 'rgba(14, 165, 233, 0.5)',
          borderColor: 'rgb(14, 165, 233)',
          borderWidth: 1,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: function(v) { return 'Rp ' + (v >= 1e6 ? (v/1e6) + 'jt' : v); }
            }
          }
        }
      }
    });
  }

  if (document.getElementById('chartCustomerType')) {
    new Chart(document.getElementById('chartCustomerType'), {
      type: 'doughnut',
      data: {
        labels: ['Hotspot', 'PPPoE'],
        datasets: [{
          data: [customerByType.hotspot || 0, customerByType.pppoe || 0],
          backgroundColor: ['#0ea5e9', '#10b981'],
          borderWidth: 0,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } },
      }
    });
  }

  if (document.getElementById('chartBillsStatus')) {
    new Chart(document.getElementById('chartBillsStatus'), {
      type: 'doughnut',
      data: {
        labels: ['Lunas', 'Belum Lunas'],
        datasets: [{
          data: [billsByStatus.paid || 0, billsByStatus.unpaid || 0],
          backgroundColor: ['#10b981', '#f59e0b'],
          borderWidth: 0,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } },
      }
    });
  }
})();
  </script>
</body>
</html>
