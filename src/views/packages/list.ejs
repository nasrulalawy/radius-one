<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: typeof active !== 'undefined' ? active : 'packages', subactive: typeof subactive !== 'undefined' ? subactive : undefined, user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: 'Paket' }) %>
    <div class="app-content">
    <div class="page-header">
      <h1><%= title %></h1>
      <a href="/packages/add" class="btn btn-primary">+ Tambah Paket</a>
    </div>
    <div class="card">
      <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Nama</th><th>Tipe</th><th>Harga/bulan</th><th>Limit</th><th>Aksi</th></tr>
        </thead>
        <tbody>
          <% if (packages.length) { packages.forEach(function(p) { %>
          <tr>
            <td><%= p.name %></td>
            <td><%= p.type %></td>
            <td>Rp <%= Number(p.price_monthly).toLocaleString('id-ID') %></td>
            <td><%= p.speed_limit || '-' %></td>
            <td>
              <a href="/packages/edit/<%= p.id %>" class="btn btn-sm btn-primary">Edit</a>
              <form method="post" action="/packages/delete/<%= p.id %>" style="display:inline;" onsubmit="return confirm('Hapus paket ini?');">
                <button type="submit" class="btn btn-sm btn-danger">Hapus</button>
              </form>
            </td>
          </tr>
          <% }); } else { %>
          <tr><td colspan="5" style="color: var(--muted);">Belum ada paket. <a href="/packages/add">Tambah paket</a>.</td></tr>
          <% } %>
        </tbody>
      </table>
      </div>
    </div>
    </div>
  </div>
</body>
</html>
