<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Radius One</title>
  <link rel="stylesheet" href="/css/modern.css">
</head>
<body class="app-with-sidebar">
  <%- include('../partials/sidebar', { active: 'packages', user }) %>
  <div class="app-main">
    <%- include('../partials/topbar', { title: title }) %>
    <div class="app-content">
    <h1><%= title %></h1>
    <div class="card">
      <form method="post" action="/packages/save">
        <% if (pkg && pkg.id) { %><input type="hidden" name="id" value="<%= pkg.id %>"><% } %>
        <div class="form-group">
          <label>Nama Paket</label>
          <input type="text" name="name" value="<%= pkg ? pkg.name : '' %>" required>
        </div>
        <div class="form-group">
          <label>Tipe</label>
          <select name="type">
            <option value="pppoe" <%= pkg && pkg.type === 'pppoe' ? 'selected' : '' %>>PPPoE</option>
            <option value="hotspot" <%= pkg && pkg.type === 'hotspot' ? 'selected' : '' %>>Hotspot</option>
          </select>
        </div>
        <div class="form-group">
          <label>Harga per bulan (Rp)</label>
          <input type="number" name="price_monthly" value="<%= pkg ? pkg.price_monthly : '' %>" min="0" step="1000">
        </div>
        <div class="form-group">
          <label>Speed limit (contoh: 10M/10M)</label>
          <input type="text" name="speed_limit" value="<%= pkg ? (pkg.speed_limit || '') : '' %>" placeholder="Opsional">
        </div>
        <div class="form-group">
          <label>Validitas voucher (hari) - untuk Hotspot</label>
          <input type="number" name="validity_days" value="<%= pkg ? (pkg.validity_days || '') : '' %>" placeholder="Opsional">
        </div>
        <button type="submit" class="btn btn-primary">Simpan</button>
        <a href="/packages" class="btn btn-secondary" style="margin-left: 0.5rem;">Batal</a>
      </form>
    </div>
    </div>
  </div>
</body>
</html>
