<script>
(function() {
  var toggle = document.getElementById('sidebar-toggle');
  var overlay = document.getElementById('sidebar-overlay');
  if (toggle) toggle.addEventListener('click', function() { document.body.classList.toggle('sidebar-open'); });
  if (overlay) overlay.addEventListener('click', function() { document.body.classList.remove('sidebar-open'); });

  // Toggle submenu show/hide
  document.querySelectorAll('.sidebar .nav-toggle').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      var group = this.closest('.nav-item-group');
      if (!group) return;
      var isExpanded = group.classList.toggle('expanded');
      btn.setAttribute('aria-expanded', isExpanded ? 'true' : 'false');
    });
  });
})();
</script>
