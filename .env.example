# Server
PORT=3001
NODE_ENV=development
SESSION_SECRET=ubah-ini-dengan-string-acak

# Database (Supabase only)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   (service_role key dari Project Settings > API)
SUPABASE_ANON_KEY=eyJ...

# Default admin (untuk pertama kali)
# Hapus atau ubah setelah login pertama
ADMIN_USER=admin
ADMIN_EMAIL=admin@radiusone.local
ADMIN_PASS=admin123

# VPN Radius (opsional - untuk fitur seperti RL Radius)
# Disarankan kelola profile VPN dari menu VPN Radius (tersimpan di database).
# Variabel di bawah hanya fallback default (opsional):
# VPN_SERVER_ENDPOINT=IP_PUBLIK_SERVER:51820
# VPN_SERVER_PUBLIC_KEY=public_key_interface_wg0
# VPN_NETWORK=10.99.0.0/24

# RADIUS SQL (opsional - jika mode integrasi router = RADIUS)
# Backend: supabase | mysql
# RADIUS_BACKEND=supabase
#
# Supabase untuk RADIUS (opsional; jika kosong akan pakai SUPABASE_URL/SUPABASE_SERVICE_KEY)
# RADIUS_SUPABASE_URL=https://xxxx.supabase.co
# RADIUS_SUPABASE_KEY=eyJ...
#
# Prefix tabel radius (default rad => radcheck, radreply)
# RADIUS_DB_TABLE_PREFIX=rad
#
# Jika backend mysql, isi:
# RADIUS_DB_HOST=127.0.0.1
# RADIUS_DB_PORT=3306
# RADIUS_DB_USER=freeradius
# RADIUS_DB_PASS=secret
# RADIUS_DB_NAME=radius
